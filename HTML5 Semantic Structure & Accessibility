        <ul class="footer-social" role="list">
          <li>
            <a href="https://github.com/deepikar" target="_blank" rel="noopener noreferrer"
               aria-label="GitHub profile (opens in new tab)" title="GitHub">GH</a>
          </li>
          <li>
            <a href="https://linkedin.com/in/deepikar" target="_blank" rel="noopener noreferrer"
               aria-label="LinkedIn profile (opens in new tab)" title="LinkedIn">in</a>
          </li>
          <li>
            <a href="mailto:deepika@deepikar.dev"
               aria-label="Send email" title="Email">✉</a>
          </li>
        </ul>
      </nav>
    </div>
  </footer>

  <script>
    /* ══════════════════════════════════════════════
       SPA NAVIGATION
    ══════════════════════════════════════════════ */
    const pages = ['home','about','projects','contact'];

    function navigate(target) {
      if (!pages.includes(target)) return;

      pages.forEach(p => {
        const el = document.getElementById('page-' + p);
        const link = document.getElementById('nav-' + p);
        if (el) el.classList.toggle('active', p === target);
        if (link) {
          if (p === target) link.setAttribute('aria-current','page');
          else link.removeAttribute('aria-current');
        }
      });

      /* Move focus to main for screen readers */
      const main = document.getElementById('main-content');
      if (main) { main.focus(); }

      /* Close mobile nav */
      const navList = document.getElementById('primary-nav');
      if (navList) navList.classList.remove('open');
      const toggle = document.getElementById('nav-toggle');
      if (toggle) toggle.setAttribute('aria-expanded','false');

      /* Update hash for bookmarkability */
      window.location.hash = target === 'home' ? '' : target;
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    /* Restore page from hash on load */
    (function() {
      const hash = window.location.hash.replace('#','');
      if (pages.includes(hash)) navigate(hash);
    })();

    /* Mobile nav toggle */
    document.getElementById('nav-toggle').addEventListener('click', function() {
      const navList = document.getElementById('primary-nav');
      const expanded = this.getAttribute('aria-expanded') === 'true';
      this.setAttribute('aria-expanded', String(!expanded));
      navList.classList.toggle('open', !expanded);
    });

    /* Keyboard: close nav on Escape */
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        const navList = document.getElementById('primary-nav');
        navList.classList.remove('open');
        document.getElementById('nav-toggle').setAttribute('aria-expanded','false');
      }
    });

    /* ══════════════════════════════════════════════
       CONTACT FORM VALIDATION
    ══════════════════════════════════════════════ */
    function setError(groupId, show) {
      const group = document.getElementById(groupId);
      if (group) group.classList.toggle('has-error', show);
    }

    function handleSubmit(e) {
      e.preventDefault();
      const form = e.target;
      const statusEl = document.getElementById('form-status');

      const name    = form.elements['name'].value.trim();
      const email   = form.elements['email'].value.trim();
      const message = form.elements['message'].value.trim();
      const consent = form.elements['consent'].checked;

      const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      let valid = true;

      /* Field-level validation */
      setError('group-name',    !name);
      setError('group-email',   !email || !emailRe.test(email));
      setError('group-message', message.length < 20);

      /* Consent error (outside a form-group) */
      const consentErr = document.getElementById('consent-error');
      consentErr.style.display = !consent ? 'block' : 'none';

      if (!name || !email || !emailRe.test(email) || message.length < 20 || !consent) {
        valid = false;
      }

      /* Move focus to first error */
      if (!valid) {
        const firstError = form.querySelector('.has-error input, .has-error textarea')
          || document.getElementById('contact-consent');
        if (firstError) firstError.focus();

        statusEl.className = 'form-status error';
        statusEl.textContent = '⚠ Please fix the errors above and try again.';
        statusEl.style.display = 'flex';
        return;
      }

      /* Success simulation */
      statusEl.className = 'form-status success';
      statusEl.innerHTML = '✓ Message sent! I\'ll be in touch within 24 hours.';
      statusEl.style.display = 'flex';
      form.reset();
      statusEl.focus();
    }

    /* Live validation on blur */
    ['contact-name','contact-email','contact-message'].forEach(id => {
      const el = document.getElementById(id);
      if (!el) return;
      el.addEventListener('blur', function() {
        const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (id === 'contact-name')    setError('group-name',    !this.value.trim());
        if (id === 'contact-email')   setError('group-email',   !this.value.trim() || !emailRe.test(this.value));
        if (id === 'contact-message') setError('group-message', this.value.trim().length < 20);
      });
    });
  </script>
</body>
</html>
